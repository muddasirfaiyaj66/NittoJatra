# Copy to .env and set your backend URL
#
# Physical phone (Expo Go) — your PC Wi‑Fi IP on the same network:
EXPO_PUBLIC_API_URL=http://192.168.0.103:3000/api/v1
#
# Android emulator:  http://10.0.2.2:3000/api/v1
# iOS simulator:     http://localhost:3000/api/v1
#
# Restart Expo after edits: npx expo start -c
